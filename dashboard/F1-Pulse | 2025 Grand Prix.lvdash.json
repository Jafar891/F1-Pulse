{
  "datasets": [
    {
      "name": "28bf90ae",
      "displayName": "KPI: Fastest Driver (Name + Lap Time)",
      "queryLines": [
        "SELECT\r\n",
        "  full_name,\r\n",
        "  fastest_lap_s\r\n",
        "FROM f1_project.gold.driver_performance_metrics\r\n",
        "ORDER BY fastest_lap_s ASC,\r\n",
        "         full_name ASC\r\n",
        "LIMIT 1;"
      ]
    },
    {
      "name": "5e2d7fc3",
      "displayName": "KPI: Top Team by Pace",
      "queryLines": [
        "SELECT\r\n",
        "  team_name,\r\n",
        "  avg_team_pace_s\r\n",
        "FROM f1_project.gold.constructor_standings\r\n",
        "ORDER BY avg_team_pace_s ASC,\r\n",
        "         team_name ASC\r\n",
        "LIMIT 1;"
      ]
    },
    {
      "name": "efc59110",
      "displayName": "Speed vs. Consistency (Scatter Plot)",
      "queryLines": [
        "SELECT\r\n",
        "  full_name,\r\n",
        "  team_name,\r\n",
        "  avg_lap_time_s,\r\n",
        "  lap_consistency_s\r\n",
        "FROM f1_project.gold.driver_performance_metrics\r\n",
        "WHERE avg_lap_time_s IS NOT NULL\r\n",
        "  AND lap_consistency_s IS NOT NULL\r\n",
        "ORDER BY avg_lap_time_s ASC;"
      ]
    },
    {
      "name": "6ceb5f6c",
      "displayName": "Ultimate Pace Gap (Horizontal Bar Chart)",
      "queryLines": [
        "WITH FastestTeam AS (\r\n",
        "  SELECT MIN(avg_team_pace_s) AS best_overall_pace\r\n",
        "  FROM f1_project.gold.constructor_standings\r\n",
        ")\r\n",
        "\r\n",
        "SELECT\r\n",
        "  c.team_name,\r\n",
        "  c.avg_team_pace_s,\r\n",
        "  ROUND(c.avg_team_pace_s - f.best_overall_pace, 3) AS pace_delta_s\r\n",
        "FROM f1_project.gold.constructor_standings c\r\n",
        "CROSS JOIN FastestTeam f\r\n",
        "ORDER BY pace_delta_s ASC;"
      ]
    },
    {
      "name": "f39ca5c1",
      "displayName": "Race Trace (Line chart)",
      "queryLines": [
        "SELECT\r\n",
        "  lap_number,\r\n",
        "  full_name,\r\n",
        "  team_name,\r\n",
        "  rolling_avg_5lap_s\r\n",
        "FROM f1_project.gold.lap_progression\r\n",
        "WHERE rolling_avg_5lap_s IS NOT NULL\r\n",
        "ORDER BY full_name ASC,\r\n",
        "         lap_number ASC;"
      ]
    }
  ],
