{
  "name": "F1_Pulse_Daily_Sync",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "timeout_seconds": 0,
  "schedule": {
    "quartz_cron_expression": "45 58 17 ? * Wed",
    "timezone_id": "Europe/Warsaw",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "Ingest",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "01_Ingest_F1_Data",
        "source": "GIT"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    },
    {
      "task_key": "Clean",
      "depends_on": [
        {
          "task_key": "Ingest"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "02_Silver_Transformation",
        "source": "GIT"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    },
    {
      "task_key": "Aggregate",
      "depends_on": [
        {
          "task_key": "Clean"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "03_Gold_Analytics",
        "source": "GIT"
      },
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    }
  ],
  "git_source": {
    "git_url": "https://github.com/Jafar891/F1-Pulse",
    "git_provider": "gitHub",
    "git_branch": "main"
  },
  "queue": {
    "enabled": true
  },
  "performance_target": "PERFORMANCE_OPTIMIZED"
}
